# Enable Banking API credentials — switch via ENABLEBANKING_ENV=sandbox|production
ENABLEBANKING_ENV=sandbox

# Sandbox
ENABLEBANKING_SANDBOX_APPLICATION_ID=your-sandbox-uuid-here
ENABLEBANKING_SANDBOX_PRIVATE_KEY_PATH=.secrets/enablebanking_private.pem

# Production (optional — required when ENABLEBANKING_ENV=production)
ENABLEBANKING_PRODUCTION_APPLICATION_ID=your-prod-uuid-here
ENABLEBANKING_PRODUCTION_PRIVATE_KEY_PATH=.secrets/enablebanking_prod.pem

# App config
APP_HOST=127.0.0.1
APP_PORT=8000
APP_SECRET_KEY=generate-with-python-secrets-token-urlsafe-32

# Database
DATABASE_PATH=finance.db

# Session / auth
SESSION_COOKIE_NAME=finance_session
SESSION_LIFETIME_DAYS=30

# Buffer / sporiaci cieľ
BUFFER_TARGET_CZK=50000
BUFFER_PER_PAYCHECK_CZK=5000
BUFFER_CATEGORY_NAME=Sporenie

# Claude API (auto-categorization)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_CONFIDENCE_THRESHOLD=0.7
