# Enable Banking API credentials
# Sandbox environment
ENABLEBANKING_APPLICATION_ID=your-application-uuid-here
ENABLEBANKING_PRIVATE_KEY_PATH=.secrets/enablebanking_private.pem
ENABLEBANKING_ENV=sandbox

# App config
APP_HOST=127.0.0.1
APP_PORT=8000
APP_SECRET_KEY=generate-with-python-secrets-token-urlsafe-32

# Database
DATABASE_PATH=finance.db

# Session / auth
SESSION_COOKIE_NAME=finance_session
SESSION_LIFETIME_DAYS=30
